    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/postgres": "^5.0.0",
    "argon2": "^0.31.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.0",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.3.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.11.0",
    "pino-pretty": "^11.0.0",
